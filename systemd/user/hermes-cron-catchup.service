[Unit]
Description=Hermes Cron Catchup — run missed jobs after system resume
After=hermes-gateway.service
Requires=hermes-gateway.service

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /home/kali/scripts/cron_catchup.py
Environment="HERMES_HOME=/home/kali/.hermes"
Environment="HERMES_ACCEPT_HOOKS=1"
StandardOutput=journal
StandardError=journal
# Give the script enough time even on a slow boot
TimeoutStartSec=120

[Install]
WantedBy=default.target
